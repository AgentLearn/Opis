# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Editor / env
.vscode/
.env

# Rust build output
target/

# Agent iteration churn (not results)
**/_iterating.json
**/logs/

# rust-validator carries its own .git — versioned separately for now
tools/rust-validator/

# CA outputs are ephemeral — regenerated per run, never checked in
# (schemas, Rust gate crates, docker compose, the whole runnable stack;
#  only evidence reports persist, and those live with GA)
agents/output/*/ca/
docker-compose*.yml
compose.yaml
