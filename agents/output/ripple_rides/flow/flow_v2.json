{
  "name": "ripple_rides",
  "version": 2,
  "description": "On-demand ride-hailing platform connecting riders with nearby available drivers in real time.",
  "archetypes": {
    "ride_request": {
      "extends": "order",
      "description": "A rider's request for a ride, including pickup and destination locations"
    },
    "ride_booking": {
      "extends": "accepted_order",
      "description": "A ride request that has passed intake validation and is ready for dispatch"
    },
    "rejected_ride_request": {
      "extends": "rejected_order",
      "description": "A ride request that failed validation or was rate-limited"
    },
    "ride_payment": {
      "extends": "payment",
      "description": "Payment transaction for a completed ride"
    },
    "ride_payment_confirmed": {
      "extends": "payment_confirmed",
      "description": "A ride payment that was successfully authorised"
    },
    "ride_payment_failed": {
      "extends": "payment_failed",
      "description": "A ride payment that was declined"
    },
    "pickup_location": {
      "extends": "location",
      "description": "The rider's requested pickup point"
    },
    "driver_location": {
      "extends": "location",
      "description": "A driver's current geographic position"
    },
    "arrival_estimate": {
      "extends": "estimate",
      "description": "Estimated time for a driver to arrive at pickup"
    },
    "zone_routing_decision": {
      "extends": "routing_decision",
      "description": "Routing and zone classification decision for a ride request"
    },
    "surge_pricing_update": {
      "extends": "menu_update",
      "description": "A pricing catalogue update triggered by high-demand zone conditions"
    },
    "driver_dispatch_command": {
      "extends": "command",
      "description": "Instruction sent to a driver to accept and begin a ride"
    },
    "driver_tracking_update": {
      "extends": "tracking_update",
      "description": "Real-time position or status update from a driver"
    },
    "dispatch_event": {
      "extends": "event",
      "description": "Fact that a ride was dispatched to a driver"
    },
    "cancellation_event": {
      "extends": "event",
      "description": "Fact that a rider cancelled a ride request"
    },
    "driver_no_accept_event": {
      "extends": "event",
      "description": "Fact that a driver failed to accept an assigned ride within the window"
    },
    "ride_complete_event": {
      "extends": "event",
      "description": "Fact that a ride was completed and payment confirmed"
    },
    "rating_event": {
      "extends": "event",
      "description": "Fact that a rating was submitted for a rider or driver after ride completion"
    },
    "rider_auth_request": {
      "extends": "auth_request",
      "description": "Authentication request from a rider's mobile app"
    },
    "driver_auth_request": {
      "extends": "auth_request",
      "description": "Authentication request from a driver"
    },
    "surge_inventory_update": {
      "extends": "inventory_update",
      "description": "Zone inventory/capacity state update used by order_validator during surge"
    },
    "ride_complete_notification": {
      "extends": "notification",
      "description": "Notification sent to rider and driver upon ride completion"
    },
    "suspension_command": {
      "extends": "command",
      "description": "Command to temporarily suspend a driver from receiving new assignments"
    },
    "cooldown_command": {
      "extends": "command",
      "description": "Command to apply a cooldown restriction to a rider for repeated late cancellations"
    }
  },
  "loci": {
    "RiderApp": {
      "description": "Rider-facing mobile application; source of ride requests and cancellations",
      "source": true
    },
    "DriverApp": {
      "description": "Driver-facing mobile application; source of location updates and accept/reject signals",
      "source": true
    },
    "PaymentGateway": {
      "description": "External payment processor for ride fare transactions",
      "source": false
    },
    "ZoneDemandMonitor": {
      "description": "Background service tracking demand levels and triggering surge conditions per zone",
      "source": true
    },
    "NotificationService": {
      "description": "Outbound notification delivery service for riders and drivers",
      "source": false
    },
    "RatingService": {
      "description": "Collects post-ride ratings from riders and drivers",
      "source": true
    },
    "AuditLog": {
      "description": "Persistent event store for all recorded system events",
      "source": false
    },
    "DispatchRouter": {
      "description": "Internal routing service that classifies ride requests by zone and computes routing decisions",
      "source": false
    }
  },
  "gates": {
    "RiderAuthSentinel": {
      "gate_template": "sentinel_auth",
      "kind": "sentinel",
      "requires": [
        "rider_auth_request"
      ],
      "emits": [
        {
          "outcome": "authenticated",
          "flows": [
            "auth_token"
          ]
        }
      ],
      "auth_required": false
    },
    "DriverAuthSentinel": {
      "gate_template": "sentinel_auth",
      "kind": "sentinel",
      "requires": [
        "driver_auth_request"
      ],
      "emits": [
        {
          "outcome": "authenticated",
          "flows": [
            "auth_token"
          ]
        }
      ],
      "auth_required": false
    },
    "RideRequestIntake": {
      "gate_template": "order_intake",
      "kind": "gate",
      "requires": [
        "ride_request",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "accepted",
          "flows": [
            "ride_booking"
          ]
        },
        {
          "outcome": "rejected",
          "flows": [
            "rejected_ride_request"
          ]
        }
      ],
      "window_ms": 5000,
      "auth_required": true
    },
    "ZoneRouter": {
      "gate_template": "delivery_router",
      "kind": "gate",
      "requires": [
        "ride_request",
        "pickup_location"
      ],
      "emits": [
        {
          "outcome": "routed",
          "flows": [
            "zone_routing_decision"
          ]
        }
      ],
      "auth_required": false
    },
    "SurgeRateLimiter": {
      "gate_template": "zone_regulator",
      "kind": "regulator",
      "requires": [
        "ride_request",
        "zone_routing_decision"
      ],
      "emits": [
        {
          "outcome": "allowed",
          "flows": [
            "ride_request"
          ]
        },
        {
          "outcome": "suppressed",
          "flows": [
            "rejected_ride_request"
          ]
        }
      ],
      "auth_required": false
    },
    "SurgePricingManager": {
      "gate_template": "menu_manager",
      "kind": "gate",
      "requires": [
        "surge_pricing_update",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "applied",
          "flows": [
            "surge_inventory_update"
          ]
        },
        {
          "outcome": "acknowledged",
          "flows": [
            "ack"
          ]
        }
      ],
      "auth_required": true
    },
    "RideBookingValidator": {
      "gate_template": "order_validator",
      "kind": "gate",
      "requires": [
        "ride_booking",
        "ride_payment_confirmed",
        "surge_inventory_update",
        "zone_routing_decision"
      ],
      "emits": [
        {
          "outcome": "validated",
          "flows": [
            "ride_booking"
          ]
        },
        {
          "outcome": "rejected",
          "flows": [
            "rejected_ride_request"
          ]
        }
      ],
      "window_ms": 10000,
      "auth_required": true
    },
    "ArrivalEstimator": {
      "gate_template": "pickup_estimator",
      "kind": "gate",
      "requires": [
        "ride_booking",
        "driver_location"
      ],
      "emits": [
        {
          "outcome": "estimated",
          "flows": [
            "arrival_estimate"
          ]
        }
      ],
      "auth_required": false
    },
    "MultiDriverDispatcher": {
      "gate_template": "driver_dispatcher",
      "kind": "gate",
      "requires": [
        "ride_booking",
        "zone_routing_decision",
        "driver_tracking_update"
      ],
      "logic": {
        "op": "THRESHOLD",
        "n": 2
      },
      "emits": [
        {
          "outcome": "dispatched",
          "flows": [
            "driver_dispatch_command"
          ]
        },
        {
          "outcome": "dispatch_event",
          "flows": [
            "dispatch_event"
          ]
        },
        {
          "outcome": "tracking_updated",
          "flows": [
            "driver_tracking_update"
          ]
        }
      ],
      "window_ms": 15000,
      "auth_required": true
    },
    "ReassignmentThrottle": {
      "gate_template": "repeat_event_throttle",
      "kind": "regulator",
      "requires": [
        "dispatch_event"
      ],
      "emits": [
        {
          "outcome": "reassigned",
          "flows": [
            "ride_request"
          ]
        },
        {
          "outcome": "suppressed",
          "flows": [
            "ack"
          ]
        }
      ],
      "window_ms": 30000,
      "auth_required": false
    },
    "DriverNoAcceptSuspension": {
      "gate_template": "repeat_event_throttle",
      "kind": "breaker",
      "requires": [
        "driver_no_accept_event"
      ],
      "trips_on": "driver_no_accept_event",
      "recovery_ms": 300000,
      "emits": [
        {
          "outcome": "suspended",
          "flows": [
            "suspension_command"
          ]
        },
        {
          "outcome": "warned",
          "flows": [
            "ack"
          ]
        }
      ],
      "auth_required": false
    },
    "RidePaymentProcessor": {
      "gate_template": "payment_processor",
      "kind": "gate",
      "requires": [
        "ride_payment",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "confirmed",
          "flows": [
            "ride_payment_confirmed"
          ]
        },
        {
          "outcome": "failed",
          "flows": [
            "ride_payment_failed"
          ]
        }
      ],
      "auth_required": true
    },
    "RideCompletionFinalizer": {
      "gate_template": "completion_finalizer",
      "kind": "gate",
      "requires": [
        "ride_payment_confirmed",
        "ride_booking"
      ],
      "emits": [
        {
          "outcome": "completed",
          "flows": [
            "ride_complete_event"
          ]
        },
        {
          "outcome": "notified",
          "flows": [
            "ride_complete_notification"
          ]
        }
      ],
      "auth_required": true
    },
    "RideCompletionRecorder": {
      "gate_template": "event_recorder",
      "kind": "gate",
      "requires": [
        "ride_complete_event",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "recorded",
          "flows": [
            "ack"
          ]
        }
      ],
      "auth_required": false
    },
    "RatingRecorder": {
      "gate_template": "event_recorder",
      "kind": "gate",
      "requires": [
        "rating_event",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "recorded",
          "flows": [
            "ack"
          ]
        }
      ],
      "auth_required": false
    },
    "CancellationRecorder": {
      "gate_template": "event_recorder",
      "kind": "gate",
      "requires": [
        "cancellation_event",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "recorded",
          "flows": [
            "ack"
          ]
        }
      ],
      "auth_required": false
    },
    "LateCancellationCooldown": {
      "gate_template": "repeat_event_throttle",
      "kind": "breaker",
      "requires": [
        "cancellation_event"
      ],
      "trips_on": "cancellation_event",
      "recovery_ms": 1800000,
      "emits": [
        {
          "outcome": "cooldown_applied",
          "flows": [
            "cooldown_command"
          ]
        },
        {
          "outcome": "warned",
          "flows": [
            "ack"
          ]
        }
      ],
      "auth_required": false
    }
  },
  "synapses": [
    {
      "from": "RiderApp",
      "to": "RiderAuthSentinel",
      "pulse_type": "rider_auth_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "DriverApp",
      "to": "DriverAuthSentinel",
      "pulse_type": "driver_auth_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "RiderApp",
      "to": "ZoneRouter",
      "pulse_type": "pickup_location",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "RiderApp",
      "to": "ZoneRouter",
      "pulse_type": "ride_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "ZoneRouter",
      "to": "SurgeRateLimiter",
      "pulse_type": "zone_routing_decision",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RiderApp",
      "to": "SurgeRateLimiter",
      "pulse_type": "ride_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "SurgeRateLimiter",
      "to": "RideRequestIntake",
      "pulse_type": "ride_request",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RiderAuthSentinel",
      "to": "RideRequestIntake",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RideRequestIntake",
      "to": "RiderApp",
      "pulse_type": "rejected_ride_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "SurgeRateLimiter",
      "to": "RiderApp",
      "pulse_type": "rejected_ride_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "ZoneDemandMonitor",
      "to": "RiderAuthSentinel",
      "pulse_type": "rider_auth_request",
      "medium": "lan",
      "interaction": "push"
    },
    {
      "from": "ZoneDemandMonitor",
      "to": "SurgePricingManager",
      "pulse_type": "surge_pricing_update",
      "medium": "lan",
      "interaction": "push"
    },
    {
      "from": "RiderAuthSentinel",
      "to": "SurgePricingManager",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "SurgePricingManager",
      "to": "RideBookingValidator",
      "pulse_type": "surge_inventory_update",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "SurgePricingManager",
      "to": "AuditLog",
      "pulse_type": "ack",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RideRequestIntake",
      "to": "RidePaymentProcessor",
      "pulse_type": "ride_booking",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RiderApp",
      "to": "PaymentGateway",
      "pulse_type": "ride_payment",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "PaymentGateway",
      "to": "RidePaymentProcessor",
      "pulse_type": "ride_payment",
      "medium": "lan",
      "interaction": "push"
    },
    {
      "from": "RiderAuthSentinel",
      "to": "RidePaymentProcessor",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RidePaymentProcessor",
      "to": "RideBookingValidator",
      "pulse_type": "ride_payment_confirmed",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RidePaymentProcessor",
      "to": "RiderApp",
      "pulse_type": "ride_payment_failed",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "RideRequestIntake",
      "to": "RideBookingValidator",
      "pulse_type": "ride_booking",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "ZoneRouter",
      "to": "RideBookingValidator",
      "pulse_type": "zone_routing_decision",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RiderAuthSentinel",
      "to": "RideBookingValidator",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RideBookingValidator",
      "to": "RiderApp",
      "pulse_type": "rejected_ride_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "RideBookingValidator",
      "to": "ArrivalEstimator",
      "pulse_type": "ride_booking",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DriverApp",
      "to": "ArrivalEstimator",
      "pulse_type": "driver_location",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "ArrivalEstimator",
      "to": "RiderApp",
      "pulse_type": "arrival_estimate",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "RideBookingValidator",
      "to": "MultiDriverDispatcher",
      "pulse_type": "ride_booking",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "ZoneRouter",
      "to": "MultiDriverDispatcher",
      "pulse_type": "zone_routing_decision",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DriverApp",
      "to": "MultiDriverDispatcher",
      "pulse_type": "driver_tracking_update",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "DriverAuthSentinel",
      "to": "MultiDriverDispatcher",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "MultiDriverDispatcher",
      "to": "DriverApp",
      "pulse_type": "driver_dispatch_command",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "MultiDriverDispatcher",
      "to": "ReassignmentThrottle",
      "pulse_type": "dispatch_event",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "MultiDriverDispatcher",
      "to": "DispatchRouter",
      "pulse_type": "driver_tracking_update",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "ReassignmentThrottle",
      "to": "SurgeRateLimiter",
      "pulse_type": "ride_request",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "ReassignmentThrottle",
      "to": "AuditLog",
      "pulse_type": "ack",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DriverApp",
      "to": "DriverNoAcceptSuspension",
      "pulse_type": "driver_no_accept_event",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "DriverNoAcceptSuspension",
      "to": "DriverApp",
      "pulse_type": "suspension_command",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "DriverNoAcceptSuspension",
      "to": "AuditLog",
      "pulse_type": "ack",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RideCompletionFinalizer",
      "to": "RideCompletionRecorder",
      "pulse_type": "ride_complete_event",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RidePaymentProcessor",
      "to": "RideCompletionFinalizer",
      "pulse_type": "ride_payment_confirmed",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RideBookingValidator",
      "to": "RideCompletionFinalizer",
      "pulse_type": "ride_booking",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DriverAuthSentinel",
      "to": "RideCompletionFinalizer",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RideCompletionFinalizer",
      "to": "NotificationService",
      "pulse_type": "ride_complete_notification",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RiderAuthSentinel",
      "to": "RideCompletionRecorder",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RideCompletionRecorder",
      "to": "AuditLog",
      "pulse_type": "ack",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RatingService",
      "to": "RiderAuthSentinel",
      "pulse_type": "rider_auth_request",
      "medium": "lan",
      "interaction": "push"
    },
    {
      "from": "RatingService",
      "to": "RatingRecorder",
      "pulse_type": "rating_event",
      "medium": "lan",
      "interaction": "push"
    },
    {
      "from": "RiderAuthSentinel",
      "to": "RatingRecorder",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RatingRecorder",
      "to": "AuditLog",
      "pulse_type": "ack",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RiderApp",
      "to": "CancellationRecorder",
      "pulse_type": "cancellation_event",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "RiderAuthSentinel",
      "to": "CancellationRecorder",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "CancellationRecorder",
      "to": "AuditLog",
      "pulse_type": "ack",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "RiderApp",
      "to": "LateCancellationCooldown",
      "pulse_type": "cancellation_event",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "LateCancellationCooldown",
      "to": "RiderApp",
      "pulse_type": "cooldown_command",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "LateCancellationCooldown",
      "to": "AuditLog",
      "pulse_type": "ack",
      "medium": "local",
      "interaction": "push"
    }
  ],
  "requirements": [
    {
      "id": "REQ-1",
      "text": "Riders request a ride via mobile app specifying pickup and destination locations; the request is validated and accepted or rejected.",
      "target": {
        "gate": "RideRequestIntake",
        "outcome": "accepted"
      }
    },
    {
      "id": "REQ-2",
      "text": "Ride requests are rate-limited per zone during high demand using surge zone regulation; excess requests are suppressed.",
      "target": {
        "gate": "SurgeRateLimiter",
        "outcome": "suppressed"
      }
    },
    {
      "id": "REQ-3",
      "text": "During high demand, surge pricing is applied and a zone inventory update is propagated for use in ride validation.",
      "target": {
        "gate": "SurgePricingManager",
        "outcome": "applied"
      }
    },
    {
      "id": "REQ-4",
      "text": "Each ride request is matched against multiple nearby drivers simultaneously using threshold-based multi-driver dispatch.",
