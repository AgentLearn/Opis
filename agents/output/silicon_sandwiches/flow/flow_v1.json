{
  "name": "silicon_sandwiches_order_flow",
  "version": 1,
  "description": "End-to-end order flow for Silicon Sandwiches covering payment, validation, kitchen submission, pickup estimation, delivery routing, driver dispatch, menu management, and loyalty points.",
  "archetypes": {
    "sandwich_order": {
      "extends": "order",
      "description": "A customer's sandwich order placed via mobile app or kiosk"
    },
    "sandwich_payment": {
      "extends": "payment",
      "description": "Payment tendered for a sandwich order"
    },
    "sandwich_payment_confirmed": {
      "extends": "payment_confirmed",
      "description": "Confirmed payment for a sandwich order"
    },
    "sandwich_payment_failed": {
      "extends": "payment_failed",
      "description": "Failed payment attempt for a sandwich order"
    },
    "sandwich_order_accepted": {
      "extends": "accepted_order",
      "description": "A sandwich order that passed intake and validation"
    },
    "sandwich_order_rejected": {
      "extends": "rejected_order",
      "description": "A sandwich order that failed intake or validation"
    },
    "shop_location": {
      "extends": "location",
      "description": "Physical location of a franchise shop"
    },
    "queue_estimate": {
      "extends": "estimate",
      "description": "Estimated pickup time based on current queue length"
    },
    "loyalty_reward": {
      "extends": "reward",
      "description": "Loyalty points earned or applied for a sandwich order"
    },
    "franchise_menu_update": {
      "extends": "menu_update",
      "description": "A menu or pricing change submitted by a franchise owner"
    },
    "driver_tracking_update": {
      "extends": "tracking_update",
      "description": "Real-time position or status update for a driver"
    },
    "kitchen_command": {
      "extends": "command",
      "description": "Instruction sent to the kitchen to prepare an order"
    },
    "kitchen_ack": {
      "extends": "ack",
      "description": "Acknowledgement from the kitchen that the order was received"
    },
    "dispatch_command": {
      "extends": "command",
      "description": "Instruction to dispatch a driver for a delivery order"
    },
    "dispatch_event": {
      "extends": "event",
      "description": "Fact that a driver has been dispatched"
    },
    "customer_notification": {
      "extends": "notification",
      "description": "Outbound message sent to the customer"
    },
    "menu_ack": {
      "extends": "ack",
      "description": "Acknowledgement that a menu update was applied"
    }
  },
  "loci": {
    "CustomerApp": {
      "description": "Mobile app or kiosk used by the customer to place orders and make payments",
      "source": true
    },
    "FranchiseOwner": {
      "description": "Franchise operator who manages menu and pricing for their location",
      "source": true
    },
    "MappingServiceA": {
      "description": "First external traffic-aware mapping service for delivery routing",
      "source": true
    },
    "MappingServiceB": {
      "description": "Second external traffic-aware mapping service for delivery routing",
      "source": true
    },
    "DriverApp": {
      "description": "Driver mobile app providing real-time tracking updates",
      "source": true
    },
    "KitchenDisplay": {
      "description": "Kitchen display system at the shop that receives and acknowledges orders",
      "source": false
    },
    "CustomerNotificationService": {
      "description": "Service that delivers notifications (SMS/push) to customers",
      "source": false
    },
    "DriverManagementSystem": {
      "description": "System that manages driver dispatch commands and tracking",
      "source": false
    },
    "OrderManagementSystem": {
      "description": "Internal system that records accepted and rejected orders",
      "source": false
    }
  },
  "gates": {
    "AuthCustomer": {
      "gate_template": "sentinel_auth",
      "kind": "sentinel",
      "requires": [
        "auth_request"
      ],
      "emits": [
        {
          "outcome": "authenticated",
          "flows": [
            "auth_token"
          ]
        }
      ],
      "window_ms": 5000,
      "auth_required": false
    },
    "AuthFranchiseOwner": {
      "gate_template": "sentinel_auth",
      "kind": "sentinel",
      "requires": [
        "auth_request"
      ],
      "emits": [
        {
          "outcome": "authenticated",
          "flows": [
            "auth_token"
          ]
        }
      ],
      "window_ms": 5000,
      "auth_required": false
    },
    "AuthLoyalty": {
      "gate_template": "sentinel_auth",
      "kind": "sentinel",
      "requires": [
        "auth_request"
      ],
      "emits": [
        {
          "outcome": "authenticated",
          "flows": [
            "auth_token"
          ]
        }
      ],
      "window_ms": 5000,
      "auth_required": false
    },
    "PaymentProcessor": {
      "gate_template": "payment_processor",
      "kind": "gate",
      "requires": [
        "sandwich_payment",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "confirmed",
          "flows": [
            "sandwich_payment_confirmed"
          ]
        },
        {
          "outcome": "failed",
          "flows": [
            "sandwich_payment_failed"
          ]
        }
      ],
      "window_ms": 10000,
      "auth_required": true
    },
    "OrderIntake": {
      "gate_template": "order_intake",
      "kind": "gate",
      "requires": [
        "sandwich_order",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "accepted",
          "flows": [
            "sandwich_order_accepted"
          ]
        },
        {
          "outcome": "rejected",
          "flows": [
            "sandwich_order_rejected"
          ]
        }
      ],
      "window_ms": 10000,
      "auth_required": true
    },
    "DeliveryRouterA": {
      "gate_template": "delivery_router",
      "kind": "gate",
      "requires": [
        "sandwich_order",
        "shop_location"
      ],
      "emits": [
        {
          "outcome": "routed",
          "flows": [
            "routing_decision"
          ]
        }
      ],
      "window_ms": 8000,
      "auth_required": false
    },
    "DeliveryRouterB": {
      "gate_template": "delivery_router",
      "kind": "gate",
      "requires": [
        "sandwich_order",
        "shop_location"
      ],
      "emits": [
        {
          "outcome": "routed",
          "flows": [
            "routing_decision"
          ]
        }
      ],
      "window_ms": 8000,
      "auth_required": false
    },
    "OrderValidator": {
      "gate_template": "order_validator",
      "kind": "gate",
      "requires": [
        "sandwich_order_accepted",
        "sandwich_payment_confirmed",
        "inventory_update",
        "routing_decision"
      ],
      "emits": [
        {
          "outcome": "validated",
          "flows": [
            "sandwich_order_accepted"
          ]
        },
        {
          "outcome": "rejected",
          "flows": [
            "sandwich_order_rejected"
          ]
        }
      ],
      "window_ms": 15000,
      "auth_required": true
    },
    "AuthOrderValidator": {
      "gate_template": "sentinel_auth",
      "kind": "sentinel",
      "requires": [
        "auth_request"
      ],
      "emits": [
        {
          "outcome": "authenticated",
          "flows": [
            "auth_token"
          ]
        }
      ],
      "window_ms": 5000,
      "auth_required": false
    },
    "PickupEstimator": {
      "gate_template": "pickup_estimator",
      "kind": "gate",
      "requires": [
        "sandwich_order_accepted",
        "shop_location"
      ],
      "emits": [
        {
          "outcome": "estimated",
          "flows": [
            "queue_estimate"
          ]
        }
      ],
      "window_ms": 5000,
      "auth_required": false
    },
    "ProducerSubmitter": {
      "gate_template": "producer_submitter",
      "kind": "gate",
      "requires": [
        "sandwich_order_accepted",
        "routing_decision"
      ],
      "emits": [
        {
          "outcome": "submitted",
          "flows": [
            "kitchen_command",
            "kitchen_ack"
          ]
        }
      ],
      "window_ms": 10000,
      "auth_required": true
    },
    "AuthProducerSubmitter": {
      "gate_template": "sentinel_auth",
      "kind": "sentinel",
      "requires": [
        "auth_request"
      ],
      "emits": [
        {
          "outcome": "authenticated",
          "flows": [
            "auth_token"
          ]
        }
      ],
      "window_ms": 5000,
      "auth_required": false
    },
    "DriverDispatcher": {
      "gate_template": "driver_dispatcher",
      "kind": "gate",
      "requires": [
        "sandwich_order_accepted",
        "routing_decision",
        "driver_tracking_update"
      ],
      "emits": [
        {
          "outcome": "dispatched",
          "flows": [
            "dispatch_command",
            "driver_tracking_update",
            "dispatch_event"
          ]
        },
        {
          "outcome": "tracking_updated",
          "flows": [
            "driver_tracking_update"
          ]
        }
      ],
      "window_ms": 15000,
      "auth_required": true
    },
    "AuthDriverDispatcher": {
      "gate_template": "sentinel_auth",
      "kind": "sentinel",
      "requires": [
        "auth_request"
      ],
      "emits": [
        {
          "outcome": "authenticated",
          "flows": [
            "auth_token"
          ]
        }
      ],
      "window_ms": 5000,
      "auth_required": false
    },
    "MenuManager": {
      "gate_template": "menu_manager",
      "kind": "gate",
      "requires": [
        "franchise_menu_update",
        "auth_token"
      ],
      "emits": [
        {
          "outcome": "menu_updated",
          "flows": [
            "menu_ack",
            "inventory_update"
          ]
        }
      ],
      "window_ms": 10000,
      "auth_required": true
    },
    "LoyaltyProcessor": {
      "gate_template": "loyalty_processor",
      "kind": "gate",
      "requires": [
        "sandwich_payment_confirmed",
        "auth_token",
        "loyalty_reward"
      ],
      "emits": [
        {
          "outcome": "points_applied",
          "flows": [
            "loyalty_reward",
            "customer_notification"
          ]
        }
      ],
      "window_ms": 10000,
      "auth_required": true
    }
  },
  "synapses": [
    {
      "from": "CustomerApp",
      "to": "AuthCustomer",
      "pulse_type": "auth_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "AuthCustomer",
      "to": "PaymentProcessor",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "PaymentProcessor",
      "pulse_type": "sandwich_payment",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "PaymentProcessor",
      "to": "OrderIntake",
      "pulse_type": "sandwich_payment_confirmed",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "PaymentProcessor",
      "to": "CustomerNotificationService",
      "pulse_type": "sandwich_payment_failed",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "AuthCustomer",
      "to": "OrderIntake",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "OrderIntake",
      "pulse_type": "sandwich_order",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "OrderIntake",
      "to": "OrderManagementSystem",
      "pulse_type": "sandwich_order_rejected",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "DeliveryRouterA",
      "pulse_type": "sandwich_order",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "MappingServiceA",
      "to": "DeliveryRouterA",
      "pulse_type": "shop_location",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "DeliveryRouterB",
      "pulse_type": "sandwich_order",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "MappingServiceB",
      "to": "DeliveryRouterB",
      "pulse_type": "shop_location",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "AuthOrderValidator",
      "to": "OrderValidator",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "AuthOrderValidator",
      "pulse_type": "auth_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "OrderIntake",
      "to": "OrderValidator",
      "pulse_type": "sandwich_order_accepted",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "PaymentProcessor",
      "to": "OrderValidator",
      "pulse_type": "sandwich_payment_confirmed",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "MenuManager",
      "to": "OrderValidator",
      "pulse_type": "inventory_update",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DeliveryRouterA",
      "to": "OrderValidator",
      "pulse_type": "routing_decision",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "OrderValidator",
      "to": "OrderManagementSystem",
      "pulse_type": "sandwich_order_rejected",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "OrderValidator",
      "to": "PickupEstimator",
      "pulse_type": "sandwich_order_accepted",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "MappingServiceA",
      "to": "PickupEstimator",
      "pulse_type": "shop_location",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "PickupEstimator",
      "to": "CustomerNotificationService",
      "pulse_type": "queue_estimate",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "AuthProducerSubmitter",
      "to": "ProducerSubmitter",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "AuthProducerSubmitter",
      "pulse_type": "auth_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "OrderValidator",
      "to": "ProducerSubmitter",
      "pulse_type": "sandwich_order_accepted",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DeliveryRouterA",
      "to": "ProducerSubmitter",
      "pulse_type": "routing_decision",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "ProducerSubmitter",
      "to": "KitchenDisplay",
      "pulse_type": "kitchen_command",
      "medium": "lan",
      "interaction": "push"
    },
    {
      "from": "ProducerSubmitter",
      "to": "OrderManagementSystem",
      "pulse_type": "kitchen_ack",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "AuthDriverDispatcher",
      "to": "DriverDispatcher",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "AuthDriverDispatcher",
      "pulse_type": "auth_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "OrderValidator",
      "to": "DriverDispatcher",
      "pulse_type": "sandwich_order_accepted",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DeliveryRouterB",
      "to": "DriverDispatcher",
      "pulse_type": "routing_decision",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DriverApp",
      "to": "DriverDispatcher",
      "pulse_type": "driver_tracking_update",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "DriverDispatcher",
      "to": "DriverManagementSystem",
      "pulse_type": "dispatch_command",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DriverDispatcher",
      "to": "CustomerNotificationService",
      "pulse_type": "dispatch_event",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "DriverDispatcher",
      "to": "DriverManagementSystem",
      "pulse_type": "driver_tracking_update",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "FranchiseOwner",
      "to": "AuthFranchiseOwner",
      "pulse_type": "auth_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "AuthFranchiseOwner",
      "to": "MenuManager",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "FranchiseOwner",
      "to": "MenuManager",
      "pulse_type": "franchise_menu_update",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "MenuManager",
      "to": "FranchiseOwner",
      "pulse_type": "menu_ack",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "AuthLoyalty",
      "pulse_type": "auth_request",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "AuthLoyalty",
      "to": "LoyaltyProcessor",
      "pulse_type": "auth_token",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "PaymentProcessor",
      "to": "LoyaltyProcessor",
      "pulse_type": "sandwich_payment_confirmed",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "CustomerApp",
      "to": "LoyaltyProcessor",
      "pulse_type": "loyalty_reward",
      "medium": "internet",
      "interaction": "push"
    },
    {
      "from": "LoyaltyProcessor",
      "to": "CustomerNotificationService",
      "pulse_type": "customer_notification",
      "medium": "local",
      "interaction": "push"
    },
    {
      "from": "LoyaltyProcessor",
      "to": "OrderManagementSystem",
      "pulse_type": "loyalty_reward",
      "medium": "local",
      "interaction": "push"
    }
  ],
  "requirements": [
    {
      "id": "REQ-1",
      "text": "Payment must be confirmed before an order is sent to the kitchen \u2014 PaymentProcessor confirms payment, which is required by both OrderIntake and OrderValidator before the order proceeds.",
      "target": {
        "gate": "PaymentProcessor",
        "outcome": "confirmed"
      }
    },
    {
      "id": "REQ-2",
      "text": "After payment confirmation, the system coordinates order creation, validation, and submission to the kitchen via OrderIntake, OrderValidator, and ProducerSubmitter.",
      "target": {
        "gate": "ProducerSubmitter",
        "outcome": "submitted"
      }
    },
    {
      "id": "REQ-3",
      "text": "Pickup time is estimated based on the current queue length at the chosen location via PickupEstimator.",
      "target": {
        "gate": "PickupEstimator",
        "outcome": "estimated"
      }
    },
    {
      "id": "REQ-4",
      "text": "Delivery routing integrates with two external mapping services (DeliveryRouterA and DeliveryRouterB) to compute traffic-aware directions.",
      "target": {
        "gate": "DeliveryRouterB",
        "outcome": "routed"
      }
    },
    {
      "id": "REQ-5",
      "text": "Orders are sent to the correct shop location based on routing logic \u2014 ProducerSubmitter uses the routing_decision to submit the order to the right kitchen.",
      "target": {
        "gate": "ProducerSubmitter",
        "outcome": "submitted"
      }
    },
    {
      "id": "REQ-6",
      "text": "A driver is dispatched and tracked in real time via DriverDispatcher (optional for pickup orders).",
      "target": {
        "gate": "DriverDispatcher",
        "outcome": "dispatched"
      }
    },
    {
      "id": "REQ-7",
      "text": "Franchise owners can update their own menu and pricing independently via MenuManager, authenticated by AuthFranchiseOwner.",
      "target": {
        "gate": "MenuManager",
        "outcome": "menu_updated"
      }
    },
    {
      "id": "REQ-8",
      "text": "The system tracks loyalty points per customer and applies rewards at checkout via LoyaltyProcessor.",
      "target": {
        "gate": "LoyaltyProcessor",
        "outcome": "points_applied"
      }
    }
  ]
}